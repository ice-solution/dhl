<% const app = application || {}; %>
<% const acct = app.accountLogin || {}; %>
<% const prof = app.profile || {}; %>
<% const mob = prof.mobile || (user && user.mobile) || {}; %>
<% const flight = app.flightDetails || {}; %>
<% const arrDate = flight.arrivalDate || {}; %>
<% const arrTime = flight.arrivalTime || {}; %>
<% const depDate = flight.departureDate || {}; %>
<% const depTime = flight.departureTime || {}; %>
<% const lodge = app.lodging || {}; %>
<% const issueDate = lodge.passportIssueDate || {}; %>
<% const expiryDate = lodge.passportExpiryDate || {}; %>
<% const dob = lodge.dateOfBirth || {}; %>
<% const checkIn = lodge.checkInDate || {}; %>
<% const checkOut = lodge.checkOutDate || {}; %>
<% const tour = app.culturalTour || {}; %>
<% const costume = app.costume || {}; %>
<% const photos = app.photoUpload || {}; %>
<% const emergency = app.emergencyContact || {}; %>
<% const dietarySelected = prof.dietaryRequirements || (prof.dietaryRequirement ? [prof.dietaryRequirement] : user.dietaryRequirements || []); %>
<% const office = user.officeTel || {}; %>
<% const currentCategory = category || acct.category || user.category || ''; %>
<% const fieldClass = (id) => showAppField(id) ? 'app-field' : 'app-field app-field--hidden'; %>
<% const sectionClass = (id) => showAppSection(id) ? '' : 'app-field--hidden'; %>
<% const isAdminMode = typeof adminMode !== 'undefined' && adminMode; %>
<% const formAction = isAdminMode ? ('/admin/users/' + adminUserId + '/edit') : '/application'; %>

<%- include('partials/header', { pageTitle: isAdminMode ? 'Admin - Edit Application' : 'Application - SUPER STARS' }) %>

<div class="application-form max-w-5xl mx-auto px-6 py-8">

  <% if (isAdminMode) { %>
  <div class="admin-edit-header mb-8">
    <a href="/admin/users/<%= adminUserId %>" class="admin-review-back">&larr; Back to User Review</a>
    <h2 class="admin-review-title mt-4">Edit Application</h2>
    <p class="admin-review-subtitle"><%= user.userId %> &middot; <%= user.fullName || '—' %></p>
  </div>
  <% if (success === 'saved') { %>
  <div class="admin-review-alert admin-review-alert--success mb-6">Changes saved successfully.</div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="admin-review-alert admin-review-alert--error mb-6"><%= error %></div>
  <% } %>
  <% } else { %>
  <div class="application-intro mb-8 text-sm text-gray-300 leading-relaxed space-y-3">
    <p>Dear Participant,</p>
    <p>Welcome to the DHL EOY 2025 registration portal.</p>
    <p>Please take a moment to complete your personal particulars below.</p>
    <ol class="application-intro-list list-decimal list-inside space-y-1">
      <li>It takes around 15 mins to complete your registration.</li>
      <li>Information will be kept strictly confidential to the EOY 2025 Event</li>
      <li><span class="form-required">*</span> is Mandatory Field. You are required to complete all your personal particulars.</li>
    </ol>
    <p>For assistance, please contact the Event Secretariat at <a href="mailto:apeceoy@dhl.com" class="application-intro-link">apeceoy@dhl.com</a>.</p>
  </div>
  <% } %>

  <% if (!isAdminMode) { %>
  <% if (success === 'confirmed') { %>
  <div class="bg-green-900/30 border border-green-700 text-green-300 text-sm px-4 py-3 rounded-sm mb-6">Your registration has been saved. A confirmation email has been sent to your registered email address.</div>
  <% } %>
  <% if (success === 'saved') { %>
  <div class="bg-green-900/30 border border-green-700 text-green-300 text-sm px-4 py-3 rounded-sm mb-6">Your progress has been saved.</div>
  <% } %>
  <% if (success === 'updated') { %>
  <div class="bg-green-900/30 border border-green-700 text-green-300 text-sm px-4 py-3 rounded-sm mb-6">Your information has been UPDATED!</div>
  <% } %>
  <% if (success === 'submitted') { %>
  <div class="bg-green-900/30 border border-green-700 text-green-300 text-sm px-4 py-3 rounded-sm mb-6">Your application has been submitted successfully.</div>
  <% } %>
  <% if (success === 'registered') { %>
  <div class="bg-green-900/30 border border-green-700 text-green-300 text-sm px-4 py-3 rounded-sm mb-6">Registration successful. Please continue completing your application.</div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="bg-red-900/40 border border-red-700 text-red-300 text-sm px-4 py-3 rounded-sm mb-6"><%= error %></div>
  <% } %>
  <% } %>

  <form method="POST" action="<%= formAction %>" id="applicationForm" novalidate>
    <%- include('partials/csrf-field') %>
    <input type="hidden" name="accountUserId" value="<%= acct.userId || user.userId || '' %>">

    <!-- Part 1 – Account Login -->
    <div data-app-section-wrap="profileSummary" class="<%= sectionClass('profileSummary') %> mb-8">
      <h2 class="section-title">Account Login</h2>
      <p class="text-xs text-gray-500 mb-4">You may update your account login details below.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="app-field md:col-span-2" data-app-field="category">
          <label class="form-label">Category <span class="form-required">*</span></label>
          <%- include('partials/select-field', { name: 'category', id: 'category', options: categoryOptions, selected: currentCategory, required: true }) %>
        </div>
        <div class="<%= fieldClass('jobTitle') %>" data-app-field="jobTitle">
          <label class="form-label">Job Title <span class="form-required">*</span></label>
          <input type="text" name="jobTitle" class="form-input" value="<%= acct.jobTitle || user.jobTitle || '' %>">
        </div>
        <div class="<%= fieldClass('functionUnit') %>" data-app-field="functionUnit">
          <label class="form-label">Function Unit <span class="form-required">*</span></label>
          <%- include('partials/select-field', { name: 'functionUnit', options: getOptions('functionUnit'), selected: acct.functionUnit || user.functionUnit }) %>
        </div>
        <div class="<%= fieldClass('functionUnitOthers') %> md:col-span-2" data-app-field="functionUnitOthers" id="functionUnitOthersWrap">
          <label class="form-label">Function Unit (Others) <span class="form-required">*</span></label>
          <input type="text" name="functionUnitOthers" class="form-input" value="<%= acct.functionUnitOthers || user.functionUnitOthers || '' %>">
        </div>
        <div class="<%= fieldClass('businessUnit') %>" data-app-field="businessUnit">
          <label class="form-label">Business Unit <span class="form-required">*</span></label>
          <%- include('partials/select-field', { name: 'businessUnit', options: getOptions('businessUnit'), selected: acct.businessUnit || user.businessUnit }) %>
        </div>
        <div class="<%= fieldClass('globalId') %> md:col-span-2" data-app-field="globalId">
          <label class="form-label">Global ID (GID) <span class="form-required">*</span></label>
          <input type="text" name="globalId" class="form-input" value="<%= acct.globalId || user.globalId || '' %>" maxlength="100" placeholder="Global ID (GID)">
          <p class="text-xs text-gray-400 mt-1">You may check your GID at <a href="<%= siteDocuments.gidLookup %>" class="text-gold underline" target="_blank" rel="noopener noreferrer"><%= siteDocuments.gidLookup %></a></p>
        </div>
        <div class="app-field md:col-span-2" data-app-field="accountUserId">
          <label class="form-label">Work Email Address</label>
          <input type="email" class="form-input bg-gray-100" value="<%= acct.userId || user.userId || '' %>" readonly>
        </div>
      </div>
      <div class="flex justify-end mt-4">
        <button type="submit" name="action" value="save" class="btn-gold" formnovalidate>Save Section</button>
      </div>
    </div>

    <!-- Part 2 – Profile -->
    <div data-app-section-wrap="profilePart2" class="<%= sectionClass('profilePart2') %>">
      <h2 class="section-title" data-app-section="profilePart2">Profile</h2>
      <p class="text-xs text-gray-500 mb-4">Please review and update your personal particulars.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="<%= fieldClass('salutation') %>" data-app-field="salutation">
          <label class="form-label">Salutation <span class="form-required">*</span></label>
          <%- include('partials/select-field', { name: 'salutation', options: getOptions('salutation'), selected: prof.salutation || user.salutation }) %>
        </div>
        <div class="<%= fieldClass('surname') %>" data-app-field="surname">
          <label class="form-label">Surname (As in Passport) <span class="form-required">*</span></label>
          <input type="text" name="surname" class="form-input" value="<%= prof.surname || user.surname || '' %>">
        </div>
        <div class="<%= fieldClass('firstName') %>" data-app-field="firstName">
          <label class="form-label">Given Name (As in Passport) <span class="form-required">*</span></label>
          <input type="text" name="firstName" class="form-input" value="<%= prof.firstName || user.givenName || '' %>">
        </div>
        <div class="<%= fieldClass('nameOnTag') %> md:col-span-2" data-app-field="nameOnTag">
          <label class="form-label">Name to be printed on badge <span class="form-required">*</span></label>
          <input type="text" name="nameOnTag" class="form-input" value="<%= prof.nameOnTag || user.nameOnBadge || '' %>">
        </div>
        <div class="<%= fieldClass('gender') %>" data-app-field="gender">
          <label class="form-label">Gender <span class="form-required">*</span></label>
          <%- include('partials/select-field', { name: 'gender', options: getOptions('gender'), selected: prof.gender || user.gender }) %>
        </div>
        <div class="<%= fieldClass('officeTelCountry') %> md:col-span-2" data-app-field="officeTelCountry">
          <label class="form-label">Office Phone</label>
          <div class="reg-phone-row">
            <input type="text" name="officeTelCountry" class="form-input" placeholder="Country Code" value="<%= office.countryCode || '' %>">
            <input type="text" name="officeTelArea" class="form-input" placeholder="Area Code" value="<%= office.areaCode || '' %>">
            <input type="text" name="officeTel" class="form-input" placeholder="Number" value="<%= office.number || '' %>">
          </div>
        </div>
        <div class="<%= fieldClass('mobileCountryCode') %> md:col-span-2" data-app-field="mobileCountryCode">
          <label class="form-label">Mobile Phone <span class="form-required">*</span></label>
          <div class="reg-phone-row">
            <input type="text" name="mobileCountryCode" class="form-input" placeholder="Country Code" value="<%= mob.countryCode || '' %>">
            <input type="text" name="mobileAreaCode" class="form-input" placeholder="Area Code" value="<%= mob.areaCode || '' %>">
            <input type="text" name="mobileNumber" class="form-input" placeholder="Number" value="<%= mob.number || '' %>">
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
        <div class="<%= fieldClass('specialPhysicalCondition') %>" data-app-field="specialPhysicalCondition">
          <label class="form-label">Special Physical Condition</label>
          <%- include('partials/select-field', { name: 'specialPhysicalCondition', options: getOptions('specialPhysicalCondition'), selected: prof.specialPhysicalCondition || user.specialPhysicalCondition }) %>
        </div>
        <div class="<%= fieldClass('specialPhysicalConditionYes') %>" data-app-field="specialPhysicalConditionYes">
          <label class="form-label">Please specify</label>
          <input type="text" name="specialPhysicalConditionYes" class="form-input" value="<%= prof.specialPhysicalConditionYes || user.specialPhysicalConditionDetail || '' %>">
        </div>
      </div>

      <div class="<%= fieldClass('dietaryRequirements') %> mt-4" data-app-field="dietaryRequirements">
        <p class="form-label mb-2">Special Dietary Requirements <span class="form-required">*</span></p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
          <% const dietOptions = ['No Preference','Halal - No Pork / No Lard','Strict Halal','No Beef','No Spicy','No Raw Food','No Seafood','Vegetarian','Vegan']; %>
          <% dietOptions.forEach((d) => { %>
            <label class="flex items-center gap-2 text-xs text-gray-300 cursor-pointer">
              <input type="checkbox" name="dietaryRequirements" value="<%= d %>" class="accent-gold" <%= dietarySelected.includes(d) ? 'checked' : '' %>>
              <%= d %>
            </label>
          <% }); %>
        </div>
      </div>

      <div class="<%= fieldClass('otherDietaryRequirements') %> mt-4" data-app-field="otherDietaryRequirements">
        <label class="form-label">Other Dietary Requirements / Food Allergies (if any)</label>
        <input type="text" name="otherDietaryRequirements" class="form-input" value="<%= prof.otherDietaryRequirements || user.otherDietaryRequirements || '' %>">
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
        <div class="<%= fieldClass('galaMainCourse') %>" data-app-field="galaMainCourse">
          <label class="form-label">Gala Dinner Main Course <span class="form-required">*</span></label>
          <%- include('partials/select-field', { name: 'galaMainCourse', options: getOptions('galaMainCourse'), selected: prof.galaMainCourse || user.galaMainCourse }) %>
        </div>
        <div class="<%= fieldClass('shirtSize') %>" data-app-field="shirtSize">
          <label class="form-label">T-shirt size <span class="form-required">*</span></label>
          <%- include('partials/select-field', { name: 'shirtSize', options: getOptions('shirtSize'), selected: costume.shirtSize || user.shirtSize }) %>
          <p class="text-xs text-gray-500 mt-1"><a href="<%= siteDocuments.tShirtSizeChart %>" class="text-gold underline" target="_blank" rel="noopener noreferrer">T-shirt size chart (PDF)</a></p>
        </div>
      </div>
      <div class="flex justify-end mt-4">
        <button type="submit" name="action" value="save" class="btn-gold" formnovalidate>Save Section</button>
      </div>
    </div>

    <!-- Flight Details (Part 3) -->
    <div data-app-section-wrap="flight" class="<%= sectionClass('flight') %>">
      <h2 class="section-title" data-app-section="flight">Flight Details</h2>
      <% Object.entries(flightCopyByGroup).forEach(([group, copy]) => { %>
      <div class="app-copy-block" data-flight-copy-group="<%= group %>" data-flight-block="top" <%= flightGroupByCategory[currentCategory] !== group ? 'hidden' : '' %>>
        <%- include('partials/flight-details-intro', { block: 'top', flightDetailsCopy: copy }) %>
      </div>
      <% }); %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="<%= fieldClass('arrivalDate') %>" data-app-field="arrivalDate">
          <p class="form-label mb-2">Arrival Date <span class="form-required">*</span></p>
          <%- include('partials/date-selects', { prefix: 'arrival', val: arrDate }) %>
        </div>
        <div class="<%= fieldClass('arrivalTime') %>" data-app-field="arrivalTime">
          <p class="form-label mb-2">Arrival Time (ETA) <span class="form-required">*</span></p>
          <%- include('partials/time-selects', { prefix: 'arrival', val: arrTime }) %>
        </div>
        <div class="<%= fieldClass('airlineRegistration') %>" data-app-field="airlineRegistration">
          <label class="form-label">Arrival Airline <span class="form-required">*</span></label>
          <input type="text" name="airlineRegistration" class="form-input" value="<%= flight.airlineRegistration || '' %>">
        </div>
        <div class="<%= fieldClass('arrivalFlightNo') %>" data-app-field="arrivalFlightNo">
          <label class="form-label">Arrival Flight Number <span class="form-required">*</span></label>
          <input type="text" name="arrivalFlightNo" class="form-input" value="<%= flight.arrivalFlightNo || '' %>">
        </div>
        <div class="<%= fieldClass('airportPickup') %> md:col-span-2" data-app-field="airportPickup">
          <p class="form-label mb-2">Do you require arrival pick up? <span class="form-required">*</span></p>
          <div class="radio-group flex gap-6">
            <% ['Yes','No'].forEach(v => { %>
              <label><input type="radio" name="airportPickup" value="<%= v %>" <%= flight.airportPickup === v ? 'checked' : '' %>> <%= v %></label>
            <% }); %>
          </div>
        </div>
        <div class="<%= fieldClass('departureDate') %>" data-app-field="departureDate">
          <p class="form-label mb-2">Departure Date <span class="form-required">*</span></p>
          <%- include('partials/date-selects', { prefix: 'departure', val: depDate }) %>
        </div>
        <div class="<%= fieldClass('departureTime') %>" data-app-field="departureTime">
          <p class="form-label mb-2">Departure Time (ETD) <span class="form-required">*</span></p>
          <%- include('partials/time-selects', { prefix: 'departure', val: depTime }) %>
        </div>
        <div class="<%= fieldClass('departureAirline') %>" data-app-field="departureAirline">
          <label class="form-label">Departure Airline <span class="form-required">*</span></label>
          <input type="text" name="departureAirline" class="form-input" value="<%= flight.departureAirline || '' %>">
        </div>
        <div class="<%= fieldClass('departureFlightNo') %>" data-app-field="departureFlightNo">
          <label class="form-label">Departure Flight Number <span class="form-required">*</span></label>
          <input type="text" name="departureFlightNo" class="form-input" value="<%= flight.departureFlightNo || '' %>">
        </div>
        <div class="<%= fieldClass('airportDropoff') %>" data-app-field="airportDropoff">
          <p class="form-label mb-2">Do you require departure transfer? <span class="form-required">*</span></p>
          <div class="radio-group flex gap-6">
            <% ['Yes','No'].forEach(v => { %>
              <label><input type="radio" name="airportDropoff" value="<%= v %>" <%= flight.airportDropoff === v ? 'checked' : '' %>> <%= v %></label>
            <% }); %>
          </div>
        </div>
        <div class="<%= fieldClass('apecCard') %>" data-app-field="apecCard">
          <p class="form-label mb-2">Do you have APEC Business Travel Card? <span class="form-required">*</span></p>
          <div class="radio-group flex gap-6">
            <% ['Yes','No'].forEach(v => { %>
              <label><input type="radio" name="apecCard" value="<%= v %>" <%= flight.apecCard === v ? 'checked' : '' %>> <%= v %></label>
            <% }); %>
          </div>
        </div>
      </div>
      <% categoryOptions.forEach((opt) => { %>
      <% const cat = opt.value; %>
      <% if (cat) { %>
      <% const flightBottomCopy = flightCopyByCategory[cat]; %>
      <% if (flightBottomCopy && flightBottomCopy.showBottomRemarks) { %>
      <div class="app-copy-block mt-6" data-flight-copy-category="<%= cat %>" data-flight-block="bottom" <%= currentCategory !== cat ? 'hidden' : '' %>>
        <%- include('partials/flight-details-intro', { block: 'bottom', flightDetailsCopy: flightBottomCopy }) %>
      </div>
      <% } %>
      <% } %>
      <% }); %>
      <div class="flex justify-end mt-4">
        <button type="submit" name="action" value="save" class="btn-gold" formnovalidate>Save Section</button>
      </div>
    </div>

    <!-- Accommodation -->
    <div data-app-section-wrap="accommodation" class="<%= sectionClass('accommodation') %>">
      <h2 class="section-title" data-app-section="accommodation">Accommodation</h2>
      <div class="<%= fieldClass('accommodationRequired') %>" data-app-field="accommodationRequired">
        <p class="form-label mb-2">Do you require accommodation during the event period? <span class="form-required">*</span></p>
        <div class="radio-group flex gap-6">
          <% ['Yes','No'].forEach(v => { %>
            <label><input type="radio" name="accommodationRequired" value="<%= v %>" <%= (flight.accommodationRequired || accommodationAnswer) === v ? 'checked' : '' %>> <%= v %></label>
          <% }); %>
        </div>
      </div>
    </div>

    <!-- Lodging Information (Part 4) – shown when accommodation = Yes -->
    <div data-app-section-wrap="lodging" class="<%= sectionClass('lodging') %>">
      <h2 class="section-title" data-app-section="lodging">Lodging Information</h2>
      <% Object.entries(lodgingCopyByGroup).forEach(([group, copy]) => { %>
      <div class="app-copy-block" data-lodging-copy-group="<%= group %>" data-lodging-block="top" <%= lodgingGroupByCategory[currentCategory] !== group ? 'hidden' : '' %>>
        <%- include('partials/lodging-info-intro', { block: 'top', lodgingInfoCopy: copy, reservationLinkEmail: reservationLinkEmail }) %>
      </div>
      <% }); %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="<%= fieldClass('nameOnPassport') %>" data-app-field="nameOnPassport">
          <label class="form-label">Name on Passport <span class="form-required">*</span></label>
          <input type="text" name="nameOnPassport" class="form-input" value="<%= lodge.nameOnPassport || '' %>">
        </div>
        <div class="<%= fieldClass('passportNumber') %>" data-app-field="passportNumber">
          <label class="form-label">Passport Number <span class="form-required">*</span></label>
          <input type="text" name="passportNumber" class="form-input" value="<%= lodge.passportNumber || '' %>">
        </div>
        <div class="<%= fieldClass('nationality') %>" data-app-field="nationality">
          <label class="form-label">Nationality <span class="form-required">*</span></label>
          <input type="text" name="nationality" class="form-input" value="<%= lodge.nationality || '' %>">
        </div>
        <div class="<%= fieldClass('passportPlaceIssue') %>" data-app-field="passportPlaceIssue">
          <label class="form-label">Place of Issue <span class="form-required">*</span></label>
          <%- include('partials/select-field', { name: 'passportPlaceIssue', options: getOptions('passportPlaceIssue'), selected: lodge.passportPlaceIssue }) %>
        </div>
        <div class="<%= fieldClass('passportIssueDate') %>" data-app-field="passportIssueDate">
          <p class="form-label mb-2">Passport Issue Date <span class="form-required">*</span></p>
          <%- include('partials/date-selects', { prefix: 'issue', val: issueDate }) %>
        </div>
        <div class="<%= fieldClass('passportExpiryDate') %>" data-app-field="passportExpiryDate">
          <p class="form-label mb-2">Passport Expiry Date <span class="form-required">*</span></p>
          <%- include('partials/date-selects', { prefix: 'expiry', val: expiryDate }) %>
        </div>
        <div class="<%= fieldClass('dateOfBirth') %> md:col-span-2" data-app-field="dateOfBirth">
          <div class="md:w-1/2">
            <p class="form-label mb-2">Date of Birth <span class="form-required">*</span></p>
            <%- include('partials/date-selects', { prefix: 'dob', val: dob }) %>
          </div>
        </div>
        <div class="<%= fieldClass('checkInDate') %>" data-app-field="checkInDate">
          <p class="form-label mb-2">Check-in Date <span class="form-required">*</span></p>
          <%- include('partials/date-selects', { prefix: 'checkIn', val: checkIn }) %>
        </div>
        <div class="<%= fieldClass('checkOutDate') %>" data-app-field="checkOutDate">
          <p class="form-label mb-2">Check-out Date <span class="form-required">*</span></p>
          <%- include('partials/date-selects', { prefix: 'checkOut', val: checkOut }) %>
        </div>
        <div class="<%= fieldClass('bedType') %> md:col-span-2" data-app-field="bedType">
          <p class="form-label mb-2">Bed Type <span class="form-required">*</span></p>
          <div class="radio-group flex gap-6">
            <% ['King','Twin'].forEach(v => { %>
              <label><input type="radio" name="bedType" value="<%= v %>" <%= (lodge.bedType ? lodge.bedType === v : v === 'King') ? 'checked' : '' %>> <%= v %></label>
            <% }); %>
          </div>
        </div>
        <div class="md:col-span-2 <%= fieldClass('otherRequests') %>" data-app-field="otherRequests">
          <label class="form-label">Other Request(s)</label>
          <textarea name="otherRequests" class="form-input h-24 resize-y"><%= lodge.otherRequests || '' %></textarea>
        </div>
      </div>
      <% categoryOptions.forEach((opt) => { %>
      <% const cat = opt.value; %>
      <% if (cat) { %>
      <% const remarksCopy = lodgingCopyByCategory[cat]; %>
      <% if (remarksCopy && remarksCopy.showRemarks) { %>
      <div class="app-copy-block" data-lodging-copy-category="<%= cat %>" data-lodging-block="remarks" <%= currentCategory !== cat ? 'hidden' : '' %>>
        <%- include('partials/lodging-info-intro', { block: 'remarks', lodgingInfoCopy: remarksCopy }) %>
      </div>
      <% } %>
      <% } %>
      <% }); %>
    </div>

    <!-- Tour Selection (Awardees only) -->
    <div data-app-section-wrap="tour" class="<%= sectionClass('tour') %>">
      <h2 class="section-title" data-app-section="tour">Tour Selection</h2>
      <p class="text-xs text-gray-400 mb-4">Please select one daytime activities option for 9 Sep</p>
      <div class="max-w-md <%= fieldClass('tourSelection') %>" data-app-field="tourSelection">
        <%- include('partials/select-field', { name: 'tourSelection', options: getOptions('tour'), selected: tour.tourSelection }) %>
      </div>
      <div class="flex justify-end mt-4">
        <button type="submit" name="action" value="save" class="btn-gold" formnovalidate>Save Section</button>
      </div>
    </div>

    <!-- Photo Upload (Awardees only) -->
    <div data-app-section-wrap="photo" class="<%= sectionClass('photo') %>">
      <h2 class="section-title" data-app-section="photo">Photo Upload</h2>
      <%- include('partials/photo-upload-intro') %>
      <div class="app-photo-upload-fields space-y-4">
        <div class="<%= fieldClass('uniformPhoto') %>" data-app-field="uniformPhoto">
          <label class="form-label">DHL Photo <span class="form-required">*</span></label>
          <% if (photos.uniformPhoto && photos.uniformPhoto.startsWith('/uploads/')) { %>
          <div class="app-photo-preview">
            <img src="<%= photos.uniformPhoto %>" alt="Uploaded DHL Photo">
            <p class="app-photo-preview-label">Current upload</p>
          </div>
          <% } %>
          <input type="file" name="uniformPhotoFile" accept="image/jpeg,.jpg,.jpeg,image/png,.png" class="form-input">
          <input type="hidden" name="uniformPhoto" value="<%= photos.uniformPhoto || '' %>">
        </div>
        <div class="<%= fieldClass('nicePhoto') %>" data-app-field="nicePhoto">
          <label class="form-label">Nice photo of yourself <span class="form-required">*</span></label>
          <% if (photos.nicePhoto && photos.nicePhoto.startsWith('/uploads/')) { %>
          <div class="app-photo-preview">
            <img src="<%= photos.nicePhoto %>" alt="Uploaded nice photo">
            <p class="app-photo-preview-label">Current upload</p>
          </div>
          <% } %>
          <input type="file" name="nicePhotoFile" accept="image/jpeg,.jpg,.jpeg,image/png,.png" class="form-input">
          <input type="hidden" name="nicePhoto" value="<%= photos.nicePhoto || '' %>">
        </div>
        <div class="<%= fieldClass('winnerMessage') %>" data-app-field="winnerMessage">
          <label class="form-label">Winner's Message</label>
          <textarea name="winnerMessage" class="form-input h-24 resize-y"><%= photos.winnerMessage || '' %></textarea>
        </div>
      </div>
      <div class="flex justify-end mt-4">
        <button type="submit" name="action" value="save" class="btn-gold" formnovalidate>Save Section</button>
      </div>
    </div>

    <!-- Emergency Personal Contact -->
    <div data-app-section-wrap="emergency" class="<%= sectionClass('emergency') %>">
      <h2 class="section-title" data-app-section="emergency">Emergency Personal Contact</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="<%= fieldClass('emergencyName') %>" data-app-field="emergencyName">
          <label class="form-label">Name <span class="form-required">*</span></label>
          <input type="text" name="emergencyName" class="form-input" value="<%= emergency.name || '' %>">
        </div>
        <div class="<%= fieldClass('emergencyContactNumber') %>" data-app-field="emergencyContactNumber">
          <label class="form-label">Contact Number <span class="form-required">*</span></label>
          <input type="text" name="emergencyContactNumber" class="form-input" placeholder="Country Code - Area Code - Number" value="<%= emergency.contactNumber || '' %>">
        </div>
        <div class="<%= fieldClass('emergencyRelationship') %>" data-app-field="emergencyRelationship">
          <label class="form-label">Relationship <span class="form-required">*</span></label>
          <input type="text" name="emergencyRelationship" class="form-input" value="<%= emergency.relationship || '' %>">
        </div>
      </div>
    </div>

    <!-- Agreement -->
    <div data-app-section-wrap="agreement" class="<%= sectionClass('agreement') %>">
      <h2 class="section-title" data-app-section="agreement">Agreement</h2>
      <%- include('partials/agreement-block', {
        checkboxName: 'agreementAccepted',
        checked: !!(app.agreementAccepted || user.photoConsent),
        required: true,
      }) %>
      <%- include('partials/social-event-policy-block', {
        checkboxName: 'socialEventPolicyAccepted',
        checked: !!(app.socialEventPolicyAccepted || user.socialEventPolicyConsent),
        required: true,
      }) %>
    </div>

    <div class="flex justify-end gap-4 mt-10 mb-8">
      <% if (isAdminMode) { %>
      <a href="/admin/users/<%= adminUserId %>" class="btn-back">Cancel</a>
      <button type="submit" name="action" value="save" class="btn-gold" formnovalidate>Save Changes</button>
      <% } else { %>
      <button type="submit" name="action" value="save" class="btn-gold">Save Draft</button>
      <button type="submit" name="action" value="submit" class="btn-gold">Submit Application</button>
      <% } %>
    </div>
  </form>
</div>

<script>
  window.APP_VISIBILITY = <%- JSON.stringify(appVisibilityMatrix) %>;
  window.APP_CATEGORY = <%- JSON.stringify(currentCategory) %>;
  window.APP_SECTIONS = <%- JSON.stringify(appSections) %>;
  window.APP_LODGING_REMARKS_BY_CATEGORY = <%- JSON.stringify(lodgingRemarksByCategory) %>;
  window.APP_FLIGHT_GROUP_BY_CATEGORY = <%- JSON.stringify(flightGroupByCategory) %>;
  window.APP_LODGING_GROUP_BY_CATEGORY = <%- JSON.stringify(lodgingGroupByCategory) %>;
  window.APP_LODGING_WITHOUT_ACCOMMODATION = <%- JSON.stringify(lodgingWithoutAccommodationByCategory) %>;
  window.APP_ACCOMMODATION = <%- JSON.stringify(accommodationAnswer || '') %>;
</script>
<script src="/js/application-form.js"></script>
<%- include('partials/footer') %>
