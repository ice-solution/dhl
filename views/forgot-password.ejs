<%- include('partials/header', { pageTitle: 'Forgot Password - SUPER STARS', showNav: false }) %>

<div class="forgot-password-page max-w-xl mx-auto px-6 py-16">
  <div class="forgot-password-header">
    <h2 class="forgot-password-title">Forgotten your password?</h2>
    <p class="forgot-password-instruction">Please fill in your registered email</p>
  </div>

  <% if (error) { %>
  <div class="forgot-password-alert forgot-password-alert--error"><%= error %></div>
  <% } %>
  <% if (success) { %>
  <div class="forgot-password-alert forgot-password-alert--success"><%= success %></div>
  <% } %>

  <% if (!success) { %>
  <form method="POST" action="/forgot-password" class="forgot-password-form">
    <div>
      <label class="form-label" for="email"><span class="form-required">*</span> Email</label>
      <input
        type="email"
        id="email"
        name="email"
        class="form-input"
        required
        autocomplete="email"
        placeholder="Email"
        value="<%= typeof email !== 'undefined' ? email : '' %>"
      >
    </div>
    <div class="pt-2">
      <button type="submit" class="btn-gold">Submit</button>
    </div>
  </form>
  <% } else { %>
  <div class="pt-4">
    <a href="/login" class="btn-gold inline-block no-underline">Back to Login</a>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
