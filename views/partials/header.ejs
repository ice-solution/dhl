<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'SUPER STARS' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            gold: '#C9A84C',
            'gold-light': '#E8D5A3',
            'gold-dark': '#9A7B2F',
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/css/custom.css">
</head>
<body class="bg-black text-white min-h-screen flex flex-col">

<header class="site-header<%= (typeof showNav === 'undefined' || !showNav) ? ' site-header--solo' : '' %>">
  <div class="site-header-brand">
    <img src="/images/logo.jpg" alt="DHL Super Stars Logo" class="site-logo">
    <img src="/images/company.jpg" alt="Super Stars Employee of the Year" class="site-company">
  </div>

  <% if (typeof showNav !== 'undefined' && showNav) { %>
  <nav class="nav-bar">
    <div class="nav-bar-inner">
      <a href="/account" class="nav-bar-link">My Account</a>
      <a href="/logout" class="nav-bar-link">Logout</a>
    </div>
  </nav>
  <% } %>
</header>

<main class="flex-1">
