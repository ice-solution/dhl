<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'SUPER STARS' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,300;0,400;0,700;1,400&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            gold: '#C9A84C',
            'gold-light': '#E8D5A3',
            'gold-dark': '#9A7B2F',
          },
          fontFamily: {
            sans: ['Delivery_W_Rg', 'Lato', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/css/custom.css">
</head>
<body class="bg-black text-white min-h-screen flex flex-col">

<header class="site-header<%= (typeof navType === 'undefined' || navType !== 'home') && (typeof showNav === 'undefined' || !showNav) ? ' site-header--solo' : '' %>">
  <div class="site-header-brand">
    <img src="/images/logo.jpg" alt="DHL Super Stars Logo" class="site-logo">
    <img src="/images/company.jpg" alt="Super Stars Employee of the Year" class="site-company">
  </div>

  <% if (typeof navType !== 'undefined' && navType === 'home') { %>
  <nav class="nav-bar">
    <div class="nav-bar-inner nav-bar-inner--wrap">
      <a href="#home" class="nav-bar-link">Home</a>
      <a href="#registration" class="nav-bar-link">Registration</a>
      <a href="#visa" class="nav-bar-link">Seoul Visa</a>
      <a href="#hotel" class="nav-bar-link">Hotel</a>
      <a href="#seoul-info" class="nav-bar-link">Seoul Info</a>
      <a href="#contact" class="nav-bar-link">Contact</a>
      <a href="/login" class="nav-bar-link">Login</a>
    </div>
  </nav>
  <% } else if (typeof showNav !== 'undefined' && showNav) { %>
  <nav class="nav-bar">
    <div class="nav-bar-inner">
      <a href="/account" class="nav-bar-link">My Account</a>
      <a href="/logout" class="nav-bar-link">Logout</a>
    </div>
  </nav>
  <% } %>
</header>

<main class="flex-1">
