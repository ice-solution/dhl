<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <% const title = typeof pageTitle !== 'undefined' ? pageTitle : 'SUPER STARS'; %>
  <% const description = typeof metaDescription !== 'undefined' ? metaDescription : ''; %>
  <% const ogTitle = typeof metaOgTitle !== 'undefined' ? metaOgTitle : title; %>
  <% const ogDescription = typeof metaOgDescription !== 'undefined' ? metaOgDescription : description; %>
  <% const ogImage = typeof metaOgImage !== 'undefined' ? metaOgImage : ''; %>
  <% const ogUrl = typeof metaOgUrl !== 'undefined' ? metaOgUrl : ''; %>
  <% const siteName = typeof metaSiteName !== 'undefined' ? metaSiteName : 'DHL Super Stars'; %>
  <title><%= title %></title>
  <% if (description) { %>
  <meta name="description" content="<%= description %>">
  <% } %>
  <% if (ogTitle || ogDescription || ogImage || ogUrl) { %>
  <meta property="og:type" content="website">
  <meta property="og:locale" content="en_US">
  <meta property="og:site_name" content="<%= siteName %>">
  <% if (ogTitle) { %><meta property="og:title" content="<%= ogTitle %>"><% } %>
  <% if (ogDescription) { %><meta property="og:description" content="<%= ogDescription %>"><% } %>
  <% if (ogImage) { %><meta property="og:image" content="<%= ogImage %>"><% } %>
  <% if (ogUrl) { %><meta property="og:url" content="<%= ogUrl %>"><% } %>
  <meta name="twitter:card" content="summary_large_image">
  <% if (ogTitle) { %><meta name="twitter:title" content="<%= ogTitle %>"><% } %>
  <% if (ogDescription) { %><meta name="twitter:description" content="<%= ogDescription %>"><% } %>
  <% if (ogImage) { %><meta name="twitter:image" content="<%= ogImage %>"><% } %>
  <% } %>
  <% if (ogUrl) { %><link rel="canonical" href="<%= ogUrl %>"><% } %>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            gold: '#C9A84C',
            'gold-light': '#E8D5A3',
            'gold-dark': '#9A7B2F',
          },
          fontFamily: {
            sans: ['Delivery', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/css/custom.css">
</head>
<body class="bg-black text-white min-h-screen flex flex-col">

<header class="site-header<%= (typeof navType === 'undefined' || navType !== 'home') && (typeof showNav === 'undefined' || !showNav) ? ' site-header--solo' : '' %>">
  <a href="/" class="site-header-brand">
    <img src="/images/logo.png" alt="DHL Super Stars Employee of the Year" class="site-logo">
  </a>

  <% if (typeof navType !== 'undefined' && navType === 'home') { %>
  <% const onRegisterFlow = typeof activeNav !== 'undefined' && activeNav === 'registration'; %>
  <% const navRoot = onRegisterFlow ? '/' : ''; %>
  <nav class="nav-bar">
    <div class="nav-bar-inner nav-bar-inner--wrap">
      <a href="<%= navRoot %>#home" class="nav-bar-link">Home</a>
      <a href="<%= onRegisterFlow ? '/register' : navRoot + '#registration' %>" class="nav-bar-link<%= onRegisterFlow ? ' nav-bar-link--active' : '' %>">Registration</a>
      <a href="<%= navRoot %>#visa" class="nav-bar-link">Seoul Visa</a>
      <a href="<%= navRoot %>#hotel" class="nav-bar-link">Hotel</a>
      <a href="<%= navRoot %>#seoul-info" class="nav-bar-link">Seoul Info</a>
      <a href="<%= navRoot %>#contact" class="nav-bar-link">Contact</a>
      <% if (session && session.userId) { %>
      <a href="/account" class="nav-bar-link">My Account</a>
      <% } else { %>
      <a href="/login" class="nav-bar-link">Login</a>
      <% } %>
    </div>
  </nav>
  <% } else if (typeof showNav !== 'undefined' && showNav) { %>
  <nav class="nav-bar">
    <div class="nav-bar-inner nav-bar-inner--wrap">
      <a href="/" class="nav-bar-link">Home</a>
      <a href="/account" class="nav-bar-link">My Account</a>
      <a href="/logout" class="nav-bar-link">Logout</a>
    </div>
  </nav>
  <% } %>
</header>

<main class="flex-1">
