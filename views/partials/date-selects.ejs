<%#
  prefix: arrival | departure | issue | expiry | dob | checkIn | checkOut
  val: { day, month, year }
%>
<% const isFlightDate = prefix === 'arrival' || prefix === 'departure'; %>
<% const isLodgingDate = prefix === 'checkIn' || prefix === 'checkOut'; %>
<% const dateVal = val || {}; %>
<% const selectedDay = dateVal.day || ''; %>
<% const selectedMonth = dateVal.month || (isFlightDate || isLodgingDate ? '09' : ''); %>
<% const selectedYear = dateVal.year || (isFlightDate ? '2026' : ''); %>
<% const dayOpts = getDateOptions(prefix, 'day'); %>
<% const monthOpts = getDateOptions(prefix, 'month'); %>
<% const yearOpts = getDateOptions(prefix, 'year'); %>
<div class="grid grid-cols-3 gap-2">
  <div>
    <label class="form-label">Day</label>
    <select name="<%= prefix %>Day" class="form-select">
      <% if (dayOpts.length === 0) { %>
        <option value="">--</option>
        <% for (let d = 1; d <= 31; d++) { %>
          <option value="<%= String(d).padStart(2, '0') %>" <%= String(selectedDay) === String(d) || String(selectedDay) === String(d).padStart(2, '0') ? 'selected' : '' %>><%= String(d).padStart(2, '0') %></option>
        <% } %>
      <% } else { %>
        <% dayOpts.forEach((opt) => { %>
          <option value="<%= opt.value %>" <%= String(selectedDay) === String(opt.value) ? 'selected' : '' %>><%= opt.label %></option>
        <% }); %>
      <% } %>
    </select>
  </div>
  <div>
    <label class="form-label">Month</label>
    <select name="<%= prefix %>Month" class="form-select">
      <% if (monthOpts.length === 0) { %>
        <option value="">--</option>
        <% const months = ['January','February','March','April','May','June','July','August','September','October','November','December']; %>
        <% months.forEach((m, i) => { %>
          <% const mv = String(i + 1).padStart(2, '0'); %>
          <option value="<%= mv %>" <%= String(selectedMonth) === mv || String(selectedMonth) === String(i + 1) ? 'selected' : '' %>><%= m %></option>
        <% }); %>
      <% } else { %>
        <% monthOpts.forEach((opt) => { %>
          <option value="<%= opt.value %>" <%= String(selectedMonth) === String(opt.value) ? 'selected' : '' %>><%= opt.label %></option>
        <% }); %>
      <% } %>
    </select>
  </div>
  <div>
    <label class="form-label">Year</label>
    <select name="<%= prefix %>Year" class="form-select">
      <% if (yearOpts.length === 0) { %>
        <option value="">--</option>
        <% for (let y = 2026; y >= 1950; y--) { %>
          <option value="<%= y %>" <%= String(selectedYear) === String(y) ? 'selected' : '' %>><%= y %></option>
        <% } %>
      <% } else { %>
        <% yearOpts.forEach((opt) => { %>
          <option value="<%= opt.value %>" <%= String(selectedYear) === String(opt.value) ? 'selected' : '' %>><%= opt.label %></option>
        <% }); %>
      <% } %>
    </select>
  </div>
</div>
