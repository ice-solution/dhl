<%- include('../partials/header', { pageTitle: 'Admin - User List', showNav: false }) %>

<div class="max-w-6xl mx-auto px-6 py-8">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h2 class="text-xl font-semibold tracking-[0.2em] uppercase text-white">User List</h2>
      <p class="text-gray-400 text-sm mt-1">Rows highlighted in yellow indicate recent application changes.</p>
    </div>
    <a href="/admin/logout" class="text-xs text-gray-400 hover:text-white uppercase tracking-widest transition-colors">Logout</a>
  </div>

  <div class="overflow-x-auto border border-gray-800 rounded-sm">
    <table class="w-full text-sm text-left">
      <thead class="bg-gray-900 text-xs uppercase tracking-wider text-gray-400">
        <tr>
          <th class="px-4 py-3 font-medium">User ID</th>
          <th class="px-4 py-3 font-medium">Full Name</th>
          <th class="px-4 py-3 font-medium">Category</th>
          <th class="px-4 py-3 font-medium">Business Unit</th>
          <th class="px-4 py-3 font-medium">Status</th>
          <th class="px-4 py-3 font-medium">Last Updated</th>
          <th class="px-4 py-3 font-medium">Changes</th>
          <th class="px-4 py-3 font-medium">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-800">
        <% if (rows.length === 0) { %>
        <tr>
          <td colspan="8" class="px-4 py-8 text-center text-gray-500">No users found.</td>
        </tr>
        <% } %>
        <% rows.forEach(row => { %>
        <tr class="<%= row.hasChanges ? 'bg-yellow-400 text-black' : 'hover:bg-gray-900' %> transition-colors">
          <td class="px-4 py-3 font-medium"><%= row.userId %></td>
          <td class="px-4 py-3"><%= row.fullName %></td>
          <td class="px-4 py-3"><%= row.category %></td>
          <td class="px-4 py-3"><%= row.businessUnit %></td>
          <td class="px-4 py-3">
            <% if (row.status === 'submitted') { %>
              <span class="<%= row.hasChanges ? 'text-green-800 font-semibold' : 'text-green-400' %>">Submitted</span>
            <% } else if (row.status === 'draft') { %>
              <span class="<%= row.hasChanges ? 'text-orange-800' : 'text-orange-400' %>">Draft</span>
            <% } else { %>
              <span class="<%= row.hasChanges ? 'text-gray-700' : 'text-gray-500' %>">No Application</span>
            <% } %>
          </td>
          <td class="px-4 py-3 <%= row.hasChanges ? 'text-gray-800' : 'text-gray-400' %>">
            <%= row.updatedAt ? new Date(row.updatedAt).toLocaleString('en-GB', { dateStyle: 'short', timeStyle: 'short' }) : '-' %>
          </td>
          <td class="px-4 py-3">
            <% if (row.hasChanges) { %>
              <span class="inline-flex items-center gap-1 font-semibold text-black">
                <span class="w-2 h-2 rounded-full bg-black"></span>
                Updated
              </span>
            <% } else { %>
              <span class="<%= row.hasChanges ? '' : 'text-gray-500' %>">-</span>
            <% } %>
          </td>
          <td class="px-4 py-3">
            <% if (row.hasChanges && row.status !== 'none') { %>
            <form method="POST" action="/admin/acknowledge/<%= row.id %>" class="inline">
              <button type="submit" class="text-xs font-semibold uppercase tracking-wider <%= row.hasChanges ? 'text-black hover:text-gray-800 underline' : 'text-gold hover:text-gold-light' %>">
                Mark Reviewed
              </button>
            </form>
            <% } else { %>
              <span class="text-gray-500">-</span>
            <% } %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="mt-6 flex items-center gap-4 text-xs text-gray-500">
    <span class="inline-flex items-center gap-2">
      <span class="w-4 h-4 bg-yellow-400 rounded-sm border border-yellow-500"></span>
      User has unsaved/recent changes
    </span>
  </div>
</div>

<%- include('../partials/footer') %>
