<%- include('partials/header', { pageTitle: 'Set New Password - SUPER STARS' }) %>

<div class="max-w-md mx-auto px-6 py-16">
  <div class="text-center mb-10">
    <h2 class="text-xl font-semibold tracking-[0.2em] uppercase text-white mb-2">Set New Password</h2>
    <p class="text-gray-400 text-sm">You have signed in with a temporary password. Please create a new password before continuing.</p>
  </div>

  <% if (error) { %>
  <div class="bg-red-900/40 border border-red-700 text-red-300 text-sm px-4 py-3 rounded-sm mb-6">
    <%= error %>
  </div>
  <% } %>

  <form method="POST" action="/change-password" class="space-y-5">
    <%- include('partials/csrf-field') %>
    <div>
      <label class="form-label" for="password">New Password <span class="form-required">*</span></label>
      <input type="password" id="password" name="password" class="form-input" required autocomplete="new-password" minlength="6" placeholder="Enter your new password">
    </div>
    <div>
      <label class="form-label" for="confirmPassword">Confirm Password <span class="form-required">*</span></label>
      <input type="password" id="confirmPassword" name="confirmPassword" class="form-input" required autocomplete="new-password" minlength="6" placeholder="Confirm your new password">
    </div>
    <div class="pt-4 flex flex-col gap-3">
      <button type="submit" class="btn-gold w-full">Save Password</button>
      <a href="/logout" class="text-center text-xs text-gray-500 hover:text-white transition-colors uppercase tracking-widest">Logout</a>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
